# API Configuration
VITE_API_DEFAULT=https://api.yourdomain.com

# Cognito Authentication (Optional)
# Leave blank or remove these if you want to disable Cognito authentication
VITE_COGNITO_CLIENT_ID=your_client_id_here
VITE_COGNITO_USER_POOL_ID=region_poolid_here
VITE_COGNITO_REGION=ca-central-1

# Example for ca-central-1 region (from CDK):
# VITE_COGNITO_CLIENT_ID=5hbjt7mmj7f1ninb7l7q6eq79v
# VITE_COGNITO_USER_POOL_ID=ca-central-1_BSotcgUgw
# VITE_COGNITO_REGION=ca-central-1
